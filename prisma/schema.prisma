generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  UPCOMING
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  category    String
  location    String
  images      String[]
  slug        String?       @unique
  startDate   DateTime?
  budget      String?
  status      ProjectStatus @default(ACTIVE)
  isFeatured  Boolean       @default(false)
  isActive    Boolean       @default(true)
  priority    Int           @default(0)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([priority])
  @@index([isActive])
  @@index([slug])
}

model News {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  excerpt     String?   @db.Text
  images      String[]
  slug        String    @unique
  published   Boolean   @default(false)
  publishedAt DateTime?
  isFeatured  Boolean   @default(false)
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([priority])
  @@index([published, isFeatured])
}

enum InquiryStatus {
  NEW
  READ
  IN_PROGRESS
  CLOSED
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String        @db.Text
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}
